{
    "name": "precision-soft/symfony-json-form",
    "type": "symfony-bundle",
    "version": "v1.0.1",
    "description": "forms that serialize to json for frontend frameworks with symfony api backends",
    "keywords": [
        "symfony",
        "json",
        "form"
    ],
    "homepage": "https://gitlab.com/precision-soft-open-source/symfony/json-form",
    "license": "MIT",
    "authors": [
        {
            "name": "Adrian Jeledintan",
            "email": "adrian.jeledintan@precision-soft.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/http-foundation": "7.*",
        "symfony/serializer": "7.*",
        "symfony/translation-contracts": "3.*"
    },
    "require-dev": {
        "precision-soft/symfony-phpunit": "1.*",
        "friendsofphp/php-cs-fixer": "3.*",
        "phpdocumentor/reflection-docblock": "5.*",
        "squizlabs/php_codesniffer": "3.*",
        "symfony/property-access": "7.*"
    },
    "autoload": {
        "psr-4": {
            "PrecisionSoft\\Symfony\\JsonForm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PrecisionSoft\\Symfony\\JsonForm\\Test\\": "tests/"
        }
    },
    "scripts": {
        "install-hooks": [
            "[ $COMPOSER_DEV_MODE -eq 1 ] && rm -rf .git/hooks && ln -s ../dev/git-hooks .git/hooks || exit 0"
        ],
        "post-install-cmd": [
            "@install-hooks"
        ],
        "post-update-cmd": [
            "@install-hooks"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
